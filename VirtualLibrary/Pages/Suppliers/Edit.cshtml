@page "{id:int}"
@model VirtualLibrary.Pages.Suppliers.EditModel
@{
    ViewData["Title"] = "Edit Supplier";
}
<h1>Edit Supplier</h1>
<hr />
<form method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
    <input type="hidden" asp-for="Supplier.SupplierId" />
    <div class="mb-3">
        <label asp-for="Supplier.Name" class="form-label"></label>
        <input asp-for="Supplier.Name" class="form-control" />
        <span asp-validation-for="Supplier.Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Supplier.ContactInfo" class="form-label"></label>
        <input asp-for="Supplier.ContactInfo" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Supplier.Address" class="form-label"></label>
        <input asp-for="Supplier.Address" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
