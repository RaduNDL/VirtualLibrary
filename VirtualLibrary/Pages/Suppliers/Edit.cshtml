@page "{id:int}"
@model VirtualLibrary.Pages.Suppliers.EditModel
@{
    ViewData["Title"] = "Edit Supplier";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/AdminSuppliers.css">

<div class="mgmt-wrapper">
    <div class="form-container">
        <header class="mgmt-header">
            <a asp-page="Index" class="back-link"><i class='bx bx-left-arrow-alt'></i> Back to Suppliers</a>
            <h2 class="mt-2">Modify Supplier</h2>
        </header>

        <div class="form-card">
            <form method="post">
                <div asp-validation-summary="All" class="text-error-summary"></div>
                <input type="hidden" asp-for="Supplier.SupplierId" />

                <div class="input-group-modern">
                    <label asp-for="Supplier.Name"></label>
                    <div class="input-with-icon">
                        <i class='bx bx-store'></i>
                        <input asp-for="Supplier.Name" />
                    </div>
                    <span asp-validation-for="Supplier.Name" class="text-error"></span>
                </div>

                <div class="input-group-modern">
                    <label asp-for="Supplier.ContactInfo"></label>
                    <div class="input-with-icon">
                        <i class='bx bx-phone-call'></i>
                        <input asp-for="Supplier.ContactInfo" />
                    </div>
                </div>

                <div class="input-group-modern">
                    <label asp-for="Supplier.Address"></label>
                    <div class="input-with-icon">
                        <i class='bx bx-map'></i>
                        <input asp-for="Supplier.Address" />
                    </div>
                </div>

                <div class="form-actions mt-4">
                    <button type="submit" class="btn-save">
                        <i class='bx bx-save'></i> Save Changes
                    </button>
                    <a asp-page="Index" class="btn-cancel">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}