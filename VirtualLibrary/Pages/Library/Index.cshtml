@page
@model VirtualLibrary.Pages.Library.IndexModel
@{
    ViewData["Title"] = "Library";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<style>
    .library-card {
        display: flex;
        flex-direction: column;
    }

    .library-card-img {
        height: 220px;
        object-fit: cover;
    }

    .library-card-body {
        flex: 1 1 auto;
    }

    .library-card-description {
        max-height: 4.5rem;
        overflow: hidden;
    }
</style>

<div class="container mt-4">
    <div class="d-flex align-items-center justify-content-between">
        <h2 class="text-primary mb-0">Available Books</h2>

        @if (Model.Products != null && Model.Products.Any())
        {
            <span class="text-muted">
                @Model.Products.Count() book(s) found
            </span>
        }
    </div>

    <form method="get" class="mt-3 mb-3">
        <div class="input-group">
            <input type="text"
                   name="q"
                   value="@Model.q"
                   class="form-control"
                   placeholder="Search by title, author, ISBN..." />
            <button class="btn btn-outline-secondary" type="submit">Search</button>
        </div>
    </form>

    @if (Model.Products == null || !Model.Products.Any())
    {
        if (!string.IsNullOrWhiteSpace(Model.q))
        {
            <div class="alert alert-info">
                No books match "<strong>@Model.q</strong>".
                <a href="@Url.Page("/Library/Index")" class="alert-link">Clear search</a>
            </div>
        }
        else
        {
            <div class="alert alert-info">No books available yet.</div>
        }
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var product in Model.Products)
            {
                var shortDesc = product.Description;
                if (!string.IsNullOrWhiteSpace(shortDesc) && shortDesc.Length > 160)
                {
                    shortDesc = shortDesc.Substring(0, 160) + "...";
                }

                var isFavorite = Model.FavoriteProductIds != null
                && Model.FavoriteProductIds.Contains(product.Id);

                <div class="col">
                    <div class="card h-100 shadow-sm library-card">

                        <img class="card-img-top library-card-img"
                             src="~/@product.ImagePath"
                             alt="@product.Title"
                             asp-append-version="true"
                             onerror="this.src='/images/no-cover.svg';this.onerror=null;" />

                        <div class="card-body library-card-body">
                            <h5 class="card-title text-success">@product.Title</h5>

                            @if (!string.IsNullOrWhiteSpace(product.Author))
                            {
                                <p class="text-muted mb-1">@product.Author</p>
                            }

                            <p class="card-text text-muted small library-card-description">
                                @shortDesc
                            </p>

                            <p class="card-text small mt-2">
                                <strong>Category:</strong> @product.Category?.Name <br />
                                <strong>Supplier:</strong> @product.Supplier?.Name <br />
                                <strong>Price:</strong> @product.Price.ToString("0.00") RON <br />
                                <strong>Stock:</strong> @product.Stock
                            </p>
                        </div>

                        <div class="card-footer bg-white border-0 d-flex justify-content-between align-items-center">
                            <a asp-page="/Products/Details"
                               asp-route-id="@product.Id"
                               class="btn btn-outline-primary btn-sm">
                                Details
                            </a>

                            <div class="d-flex gap-2">
                                <form method="post"
                                      asp-page="/Favorites/Index"
                                      asp-page-handler="Add"
                                      class="d-inline">
                                    <input type="hidden" name="productId" value="@product.Id" />
                                    <button type="submit"
                                            class="btn btn-sm @(isFavorite ? "btn-danger" : "btn-outline-danger")"
                                            title="Add to wishlist">
                                        <i class="bi @(isFavorite ? "bi-heart-fill" : "bi-heart")"></i>
                                    </button>
                                </form>

                                <form method="post"
                                      asp-page="/Cart/Index"
                                      asp-page-handler="Add"
                                      class="d-inline">
                                    <input type="hidden" name="productId" value="@product.Id" />
                                    <button type="submit" class="btn btn-success btn-sm" title="Add to cart">
                                        <i class="bi bi-cart-plus"></i>
                                    </button>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>
