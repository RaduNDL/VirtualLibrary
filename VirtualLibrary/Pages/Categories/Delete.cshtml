@page "{id:int}"
@model VirtualLibrary.Pages.Categories.DeleteModel
@{
    ViewData["Title"] = "Remove Category";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/AdminManagement.css">

<div class="mgmt-wrapper">
    <div class="delete-confirmation-container">
        <div class="delete-card">
            <div class="delete-icon">
                <i class='bx bx-error-alt'></i>
            </div>
            <h3>Are you sure?</h3>
            <p>You are about to remove the category <strong>"@Model.Category.Name"</strong>. This action might affect products assigned to it.</p>

            <form method="post" class="delete-form">
                <button type="submit" class="btn-confirm-delete">
                    <i class='bx bx-trash'></i> Yes, Delete it
                </button>
                <a asp-page="Index" class="btn-keep">
                    No, Keep it
                </a>
            </form>
        </div>
    </div>
</div>