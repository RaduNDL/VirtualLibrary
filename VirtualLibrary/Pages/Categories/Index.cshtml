@page
@model VirtualLibrary.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Manage Categories";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/AdminManagement.css">

<div class="mgmt-wrapper">
    <div class="mgmt-container">
        <header class="mgmt-header">
            <div class="header-text">
                <h2>Categories</h2>
                <p>Manage the genres and collections of your library.</p>
            </div>
            <a asp-page="Add" class="btn-add-new">
                <i class='bx bx-plus-circle'></i> Add New Category
            </a>
        </header>

        @if (TempData["Message"] != null)
        {
            <div class="alert-success-modern">
                <i class='bx bx-check-double'></i> @TempData["Message"]
            </div>
        }

        <div class="table-card">
            <table class="mgmt-table">
                <thead>
                    <tr>
                        <th>Genre Name</th>
                        <th class="text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in Model.Categories)
                    {
                        <tr>
                            <td class="td-name">
                                <div class="name-wrapper">
                                    <div class="category-icon-small"><i class='bx bx-hash'></i></div>
                                    <span>@category.Name</span>
                                </div>
                            </td>
                            <td class="text-right">
                                <div class="actions-wrapper">
                                    <a asp-page="Edit" asp-route-id="@category.CategoryId" class="action-btn edit" title="Edit">
                                        <i class='bx bx-edit-alt'></i>
                                    </a>
                                    <a asp-page="Delete" asp-route-id="@category.CategoryId" class="action-btn delete" title="Delete">
                                        <i class='bx bx-trash'></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>