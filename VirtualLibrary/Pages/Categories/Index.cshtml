@page
@model VirtualLibrary.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Categories";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2 class="text-primary mb-3">Categories</h2>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">@TempData["Message"]</div>
    }

    <a asp-page="Add" class="btn btn-success mb-3">
        <i class="bi bi-plus-circle"></i> Add Category
    </a>

    <table class="table table-striped shadow-sm align-middle">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th style="width:200px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model.Categories)
            {
                <tr>
                    <td>@category.Name</td>
                    <td>
                        <a asp-page="Edit" asp-route-id="@category.CategoryId" class="btn btn-warning btn-sm">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <a asp-page="Delete" asp-route-id="@category.CategoryId" class="btn btn-danger btn-sm">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
