@page
@model VirtualLibrary.Pages.IndexModel
@{
    ViewData["Title"] = "Virtual Library - Home";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<section class="bg-light py-5 text-center shadow-sm rounded">
    <div class="container">
        <h1 class="display-4 fw-bold text-primary">
            Welcome to <span class="text-success">Virtual Library</span>
        </h1>
        <p class="mt-3 text-muted">
            Discover, explore, and enjoy a curated selection of books.
        </p>
        <a asp-page="/Library/Index" class="btn btn-primary btn-lg mt-2">
            Browse Library
        </a>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <h2 class="text-center mb-4 text-success">Why Choose Virtual Library?</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center p-4">
                    <i class="bi bi-collection display-5 mb-3"></i>
                    <h5 class="fw-bold">Rich Catalog</h5>
                    <p class="text-muted">Explore a wide range of books across multiple categories, all in one place.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center p-4">
                    <i class="bi bi-person-check display-5 mb-3"></i>
                    <h5 class="fw-bold">Personalized Experience</h5>
                    <p class="text-muted">Log in to save favorites, manage orders, and receive recommendations.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center p-4">
                    <i class="bi bi-shield-lock display-5 mb-3"></i>
                    <h5 class="fw-bold">Secure & Reliable</h5>
                    <p class="text-muted">Your data is safe with our modern and secure platform.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h2 class="mb-0 text-primary">Featured Books</h2>
            <a asp-page="/Library/Index" class="btn btn-outline-secondary btn-sm">
                View all
            </a>
        </div>

        <div class="row g-4">
            @if (Model.FeaturedProducts != null && Model.FeaturedProducts.Any())
            {
                foreach (var p in Model.FeaturedProducts)
                {
                    <div class="col-sm-6 col-md-4 col-lg-3">
                        <div class="card shadow-sm h-100">
                            <img class="card-img-top"
                                 src="~/@p.ImagePath"
                                 alt="@p.Title"
                                 asp-append-version="true"
                                 onerror="this.src='/images/no-cover.svg';this.onerror=null;" />

                            <div class="card-body text-center">
                                <h5 class="card-title text-truncate mb-1" title="@p.Title">@p.Title</h5>
                                <p class="card-text text-muted text-truncate mb-2">@p.Category?.Name</p>
                                <p class="text-success fw-bold mb-3">@p.Price.ToString("0.00") RON</p>

                                <a asp-page="/Products/Details"
                                   asp-route-id="@p.Id"
                                   asp-route-returnUrl="@($"{Request.Path}{Request.QueryString}")"
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye"></i> View
                                </a>

                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-center text-muted">No featured books available yet.</p>
            }
        </div>
    </div>
</section>
