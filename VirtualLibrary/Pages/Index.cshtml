@page
@model VirtualLibrary.Pages.IndexModel
@{
    ViewData["Title"] = "Virtual Library - Home";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/Home.css">

<section class="hero-section">
    <div class="hero-content">
        <h1>Welcome to <span>Virtual Library</span></h1>
        <p>Discover, explore, and enjoy a curated selection of books across multiple genres.</p>
        <a asp-page="/Library/Index" class="btn-hero">
            Browse Library <i class='bx bx-right-arrow-alt'></i>
        </a>
    </div>
</section>

<section class="features-section">
    <div class="container-custom">
        <h2 class="section-title">Why Choose Virtual Library?</h2>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">
                    <i class='bx bx-library'></i>
                </div>
                <h3>Rich Catalog</h3>
                <p>Explore a wide range of books across multiple categories, all in one place.</p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <i class='bx bx-user-check'></i>
                </div>
                <h3>Personalized Experience</h3>
                <p>Log in to save favorites, manage orders, and receive tailored recommendations.</p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <i class='bx bx-shield-quarter'></i>
                </div>
                <h3>Secure & Reliable</h3>
                <p>Your personal data and reading history are safe with our modern platform.</p>
            </div>
        </div>
    </div>
</section>

<section class="featured-section">
    <div class="container-custom">
        <div class="featured-header">
            <h2 class="section-title mb-0">Featured Books</h2>
            <a asp-page="/Library/Index" class="btn-view-all">
                View all <i class='bx bx-grid-alt'></i>
            </a>
        </div>

        @if (Model.FeaturedProducts != null && Model.FeaturedProducts.Any())
        {
            <div class="featured-grid">
                @foreach (var p in Model.FeaturedProducts)
                {
                    <div class="featured-card">
                        <div class="featured-cover">
                            <img src="~/@p.ImagePath" alt="@p.Title" asp-append-version="true" onerror="this.src='/images/no-cover.svg';this.onerror=null;" />
                            <div class="featured-price">@p.Price.ToString("0.00") RON</div>
                        </div>
                        <div class="featured-info">
                            <span class="featured-category">@p.Category?.Name</span>
                            <h4 title="@p.Title">@p.Title</h4>

                            <a asp-page="/Products/Details" asp-route-id="@p.Id" asp-route-returnUrl="@($"{Request.Path}{Request.QueryString}")" class="btn-featured-view">
                                <i class='bx bx-show'></i> View Details
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-featured">
                <i class='bx bx-book-open'></i>
                <p>No featured books available yet.</p>
            </div>
        }
    </div>
</section>