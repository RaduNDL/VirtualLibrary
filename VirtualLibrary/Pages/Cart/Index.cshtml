@page
@model VirtualLibrary.Pages.Cart.IndexModel
@{
    ViewData["Title"] = "Shopping Cart";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <h2 class="text-primary mb-3">Shopping Cart</h2>

    @if (TempData["BillingError"] is string errorMessage)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (Model.CartItems == null || !Model.CartItems.Any())
    {
        <div class="alert alert-info">Your cart is empty.</div>
    }
    else
    {
        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Product</th>
                    <th>Price</th>
                    <th style="width: 180px;">Quantity</th>
                    <th>Subtotal</th>
                    <th style="width: 120px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.CartItems)
                {
                    <tr>
                        <td class="fw-semibold">@item.Product.Title</td>
                        <td>@item.Product.Price.ToString("0.00") RON</td>
                        <td>
                            <form method="post" asp-page-handler="UpdateQuantity" class="d-flex">
                                <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                <input type="number" name="quantity" value="@item.Quantity" min="1"
                                       class="form-control form-control-sm me-2" style="width: 80px;" />
                                <button type="submit" class="btn btn-sm btn-secondary">Update</button>
                            </form>
                        </td>
                        <td>@(item.Product.Price* item.Quantity).ToString("0.00") RON</td>
                        <td>
                            <form method="post" asp-page-handler="Remove">
                                <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Remove
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <h4 class="mb-0">
                Total:
                <span class="text-success fw-bold">@Model.Total.ToString("0.00") RON</span>
            </h4>

            <a asp-page="/Billing/Index" class="btn btn-success btn-lg">
                <i class="bi bi-credit-card"></i> Proceed to Checkout
            </a>
        </div>
    }
</div>
