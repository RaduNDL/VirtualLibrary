@page
@model VirtualLibrary.Pages.Cart.IndexModel
@{
    ViewData["Title"] = "Shopping Cart";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/Cart.css">

<div class="cart-wrapper">
    <div class="cart-container">
        <header class="cart-header">
            <a asp-page="/Index" class="back-btn"><i class='bx bx-left-arrow-alt'></i> Continue Shopping</a>
            <h2>Shopping Cart</h2>
        </header>

        @if (TempData["BillingError"] is string errorMessage)
        {
            <div class="alert-error">
                <i class='bx bx-error-circle'></i> @errorMessage
            </div>
        }

        @if (Model.CartItems == null || !Model.CartItems.Any())
        {
            <div class="empty-state">
                <i class='bx bx-cart'></i>
                <h3>Your cart is empty</h3>
                <p>Looks like you haven't added anything to your cart yet.</p>
                <a asp-page="/Index" class="btn-primary">Start Browsing</a>
            </div>
        }
        else
        {
            <div class="cart-layout">
                <div class="cart-items-section">
                    <div class="cart-items-header">
                        <span class="col-product">Product</span>
                        <span class="col-qty">Quantity</span>
                        <span class="col-total">Subtotal</span>
                        <span class="col-action"></span>
                    </div>

                    @foreach (var item in Model.CartItems)
                    {
                        <div class="cart-item">
                            <div class="item-details col-product">
                                <div class="item-icon">
                                    <i class='bx bx-book-open'></i>
                                </div>
                                <div class="item-info">
                                    <h4>@item.Product.Title</h4>
                                    <span class="item-unit-price">@item.Product.Price.ToString("0.00") RON</span>
                                </div>
                            </div>

                            <div class="item-actions col-qty">
                                <form method="post" asp-page-handler="UpdateQuantity" class="qty-form">
                                    <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                    <div class="qty-input-group">
                                        <input type="number" name="quantity" value="@item.Quantity" min="1" />
                                        <button type="submit" class="btn-update" title="Update Quantity"><i class='bx bx-refresh'></i></button>
                                    </div>
                                </form>
                            </div>

                            <div class="item-subtotal col-total">
                                <span>@((item.Product.Price * item.Quantity).ToString("0.00")) RON</span>
                            </div>

                            <div class="item-remove col-action">
                                <form method="post" asp-page-handler="Remove">
                                    <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                    <button type="submit" class="btn-remove" title="Remove Item">
                                        <i class='bx bx-trash'></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>

                <div class="cart-summary-section">
                    <div class="summary-card">
                        <h3>Order Summary</h3>
                        <div class="summary-row">
                            <span>Subtotal</span>
                            <span>@Model.Total.ToString("0.00") RON</span>
                        </div>
                        <div class="summary-row">
                            <span>Shipping</span>
                            <span class="text-accent">Free</span>
                        </div>
                        <div class="divider"></div>
                        <div class="summary-row total">
                            <span>Total</span>
                            <span>@Model.Total.ToString("0.00") RON</span>
                        </div>

                        <a asp-page="/Billing/Index" class="btn-checkout">
                            Proceed to Checkout <i class='bx bx-right-arrow-alt'></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>