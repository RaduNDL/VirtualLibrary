@page
@model VirtualLibrary.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Books";
}
<div class="d-flex align-items-center justify-content-between">
    <h1 class="mb-0">Books</h1>
    <div>
        <a asp-page="Create" class="btn btn-primary">Add Book</a>
        <a asp-page="./Import" class="btn btn-outline-primary">Bulk Import</a>
    </div>
</div>
<form method="get" class="mt-3 mb-3">
    <div class="input-group">
        <input type="text" name="q" value="@Model.q" class="form-control" placeholder="Search by title, author, ISBN..." />
        <button class="btn btn-outline-secondary" type="submit">Search</button>
    </div>
</form>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3">
    @foreach (var b in Model.Products)
    {
        <div class="col">
            <div class="card h-100">
                <img class="card-img-top" src="~/@b.ImagePath" alt="@b.Title" asp-append-version="true"
                     onerror="this.src='/images/no-cover.svg';this.onerror=null;">
                <div class="card-body">
                    <h5 class="card-title text-truncate" title="@b.Title">@b.Title</h5>
                    <p class="card-text text-muted text-truncate" title="@b.Author">@b.Author</p>
                    <p class="card-text fw-semibold">@b.Price.ToString("0.00") RON</p>
                </div>
                <div class="card-footer d-flex gap-2">
                    <a asp-page="./Details" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary">Details</a>
                    <a asp-page="./Edit" asp-route-id="@b.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <a asp-page="./Delete" asp-route-id="@b.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </div>
            </div>
        </div>
    }
</div>
