@page
@model VirtualLibrary.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Books";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/AdminProducts.css">

<div class="mgmt-wrapper">
    <div class="mgmt-container-wide">
        <header class="mgmt-header flex-between">
            <div class="header-text">
                <h2><i class='bx bx-book-content'></i> Manage Books</h2>
                <p>Add, edit, and organize your library inventory.</p>
            </div>
            <div class="header-actions">
                <a asp-page="./Import" class="btn-outline-primary">
                    <i class='bx bx-cloud-download'></i> Bulk Import
                </a>
                <a asp-page="Create" class="btn-add-new">
                    <i class='bx bx-plus-circle'></i> Add Book
                </a>
            </div>
        </header>

        <form method="get" class="search-form-modern mb-4">
            <div class="search-bar">
                <i class='bx bx-search'></i>
                <input type="text" name="q" value="@Model.q" placeholder="Search by title, author, ISBN..." />
                <button type="submit">Search</button>
            </div>
        </form>

        <div class="books-admin-grid">
            @foreach (var b in Model.Products)
            {
                <div class="admin-book-card">
                    <div class="admin-cover-wrapper">
                        <img src="~/@b.ImagePath" alt="@b.Title" asp-append-version="true" onerror="this.src='/images/no-cover.svg';this.onerror=null;" />
                        <span class="price-tag">@b.Price.ToString("0.00") RON</span>
                    </div>
                    <div class="admin-book-info">
                        <h4 title="@b.Title">@b.Title</h4>
                        <p class="author" title="@b.Author">@b.Author</p>
                    </div>
                    <div class="admin-book-actions">
                        <a asp-page="./Details" asp-route-id="@b.Id" class="action-btn details" title="Details">
                            <i class='bx bx-info-circle'></i>
                        </a>
                        <a asp-page="./ManagePdf" asp-route-id="@b.Id" class="action-btn pdf" title="Manage PDF">
                            <i class='bx bxs-file-pdf'></i>
                        </a>
                        <a asp-page="./Edit" asp-route-id="@b.Id" class="action-btn edit" title="Edit">
                            <i class='bx bx-edit-alt'></i>
                        </a>
                        <a asp-page="./Delete" asp-route-id="@b.Id" class="action-btn delete" title="Delete">
                            <i class='bx bx-trash'></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>