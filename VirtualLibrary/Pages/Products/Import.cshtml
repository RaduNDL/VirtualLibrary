@page
@model VirtualLibrary.Pages.Products.ImportModel
@{
    ViewData["Title"] = "Bulk Import";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/AdminProducts.css">

<div class="mgmt-wrapper">
    <div class="mgmt-container">
        <header class="mgmt-header">
            <a asp-page="./Index" class="back-link"><i class='bx bx-left-arrow-alt'></i> Back to Books</a>
            <h2 class="mt-2">Bulk Import Books</h2>
        </header>

        <div class="form-card">
            <div class="import-info-box mb-4">
                <i class='bx bx-info-circle'></i>
                <p>
                    Import books automatically by subject keyword from <strong>Google Books API</strong>.
                    PDFs will be automatically searched on <strong>Open Library</strong> after import.
                    This process might take a few moments depending on the count.
                </p>
            </div>

            <form method="post" class="row g-4" id="importForm">
                <div class="col-md-8">
                    <div class="input-group-modern">
                        <label asp-for="Subject">Subject (ex: fiction, history, computers, science)</label>
                        <input asp-for="Subject" placeholder="Enter keyword..." />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="input-group-modern">
                        <label asp-for="Count">Count</label>
                        <input asp-for="Count" type="number" min="1" max="400" />
                    </div>
                </div>
                <div class="col-12 form-actions mt-2">
                    <button type="submit" class="btn-save" id="importBtn">
                        <i class='bx bx-cloud-download'></i> Run Import
                    </button>
                    <a asp-page="./Index" class="btn-cancel">Cancel</a>
                </div>
            </form>

            <div id="loadingOverlay" style="display:none; margin-top: 20px; padding: 30px; text-align: center; background: #f0f7ff; border-radius: 12px; border: 2px solid #3b82f6;">
                <div style="margin-bottom: 15px;">
                    <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
                <h4 style="color: #1e40af;">⏳ Importing Books...</h4>
                <p style="color: #64748b;">
                    Fetching books from Google Books API and searching for PDFs on Open Library.<br>
                    This may take <strong>30-90 seconds</strong> depending on the count. Please don't close this page.
                </p>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('importForm').addEventListener('submit', function () {
        document.getElementById('importBtn').disabled = true;
        document.getElementById('importBtn').innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Importing...';
        document.getElementById('loadingOverlay').style.display = 'block';
    });
</script>