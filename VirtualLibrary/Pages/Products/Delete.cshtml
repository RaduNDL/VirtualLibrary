@page
@model VirtualLibrary.Pages.Products.DeleteModel
@{
    ViewData["Title"] = "Delete Book";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/AdminProducts.css">

<div class="mgmt-wrapper">
    <div class="delete-confirmation-container">
        <div class="delete-card">
            <div class="delete-icon">
                <i class='bx bx-book-bookmark'></i>
            </div>
            <h3>Delete this book?</h3>
            <p>You are about to permanently delete <strong>"@Model.Product.Title"</strong>.</p>

            <div class="delete-preview-box">
                <img src="~/@Model.Product.ImagePath" alt="@Model.Product.Title" asp-append-version="true" onerror="this.src='/images/no-cover.svg';this.onerror=null;" />
                <div class="preview-details">
                    <span><strong>Author:</strong> @Model.Product.Author</span>
                    <span><strong>ISBN:</strong> @Model.Product.Isbn</span>
                    <span><strong>Category:</strong> @Model.Product.Category?.Name</span>
                </div>
            </div>

            <form method="post" class="delete-form mt-4">
                <input type="hidden" asp-for="Product.Id" />
                <button type="submit" class="btn-confirm-delete">
                    <i class='bx bx-trash'></i> Confirm Deletion
                </button>
                <a asp-page="./Index" class="btn-keep">Cancel</a>
            </form>
        </div>
    </div>
</div>