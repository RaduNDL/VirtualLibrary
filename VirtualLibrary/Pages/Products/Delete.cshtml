@page
@model VirtualLibrary.Pages.Products.DeleteModel
@{
    ViewData["Title"] = "Delete Book";
}
<h1>Delete Book</h1>
<h3>Are you sure you want to delete this?</h3>
<hr />
<div class="row">
    <div class="col-md-3">
        <img src="~/@Model.Product.ImagePath" alt="@Model.Product.Title" class="img-fluid rounded border"
             asp-append-version="true"
             onerror="this.src='/images/no-cover.svg';this.onerror=null;" />
    </div>
    <div class="col-md-9">
        <dl class="row">
            <dt class="col-sm-3">Title</dt>
            <dd class="col-sm-9">@Model.Product.Title</dd>
            <dt class="col-sm-3">Author</dt>
            <dd class="col-sm-9">@Model.Product.Author</dd>
            <dt class="col-sm-3">ISBN</dt>
            <dd class="col-sm-9">@Model.Product.Isbn</dd>
            <dt class="col-sm-3">Price</dt>
            <dd class="col-sm-9">@Model.Product.Price</dd>
            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.Product.Category?.Name</dd>
        </dl>
    </div>
</div>
<form method="post" class="mt-3">
    <input type="hidden" asp-for="Product.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
</form>
