@page "{id:int}"
@model VirtualLibrary.Pages.Products.ManagePdfModel
@{
    ViewData["Title"] = "Manage PDF";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/AdminProducts.css">

<div class="mgmt-wrapper">
    <div class="mgmt-container">
        <header class="mgmt-header flex-between">
            <div>
                <a asp-page="./Details" asp-route-id="@Model.Product!.Id" class="back-link">
                    <i class='bx bx-left-arrow-alt'></i> Back to Book
                </a>
                <h2 class="mt-2">Manage PDF Content</h2>
            </div>
        </header>

        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="alert-info-modern">
                <i class='bx bx-info-square'></i> @Html.Raw(Model.StatusMessage)
            </div>
        }

        <div class="pdf-book-summary mb-4">
            <div class="summary-text">
                <h4>@Model.Product!.Title</h4>
                <p>@(Model.Product.Author ?? "Unknown Author")</p>
            </div>

            @if (Model.Product.HasPdfAvailable)
            {
                <div class="status-box status-success">
                    <i class='bx bxs-check-circle'></i>
                    <div>
                        <strong>PDF Available</strong>
                        <span>Source: @(Model.Product.PdfSource ?? "Unknown")</span>
                    </div>
                    <a href="~/@Model.Product.PdfFilePath" target="_blank" class="btn-view-pdf">
                        <i class='bx bx-show'></i> Preview
                    </a>
                </div>
            }
            else
            {
                <div class="status-box status-warning">
                    <i class='bx bx-error-circle'></i>
                    <div>
                        <strong>No PDF Available</strong>
                        <span>Add a file to enable reading</span>
                    </div>
                </div>
            }
        </div>

        <div class="pdf-actions-grid">

            <div class="action-card primary-border">
                <div class="card-title-bar primary-bg">
                    <i class='bx bx-search-alt'></i> Open Library Search
                </div>
                <div class="card-content">
                    <p>Automatically search and download PDF from Open Library. Works best for books in the public domain.</p>
                    <form method="post" asp-page-handler="SearchOpenLibrary">
                        <input type="hidden" name="productId" value="@Model.Product!.Id" />
                        <button type="submit" class="btn-full-primary">
                            Search &amp; Fetch
                        </button>
                    </form>
                </div>
            </div>

            <div class="action-card success-border">
                <div class="card-title-bar success-bg">
                    <i class='bx bx-upload'></i> Manual Upload
                </div>
                <div class="card-content">
                    <p>Upload a PDF file manually from your device. Maximum file size: 100 MB.</p>
                    <form method="post" asp-page-handler="Upload" enctype="multipart/form-data">
                        <input type="hidden" name="productId" value="@Model.Product!.Id" />
                        <div id="uploadArea" class="drag-drop-area">
                            <i class='bx bx-cloud-upload'></i>
                            <strong>Drag and drop PDF here</strong>
                            <span>or click to browse</span>
                            <input type="file" name="pdfFile" accept=".pdf" id="fileInput" />
                        </div>
                        <button type="submit" class="btn-full-success mt-3">
                            Upload File
                        </button>
                    </form>
                </div>
            </div>

            <div class="action-card" style="border: 2px solid #c7d2fe; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                <div class="card-title-bar" style="background: #4f46e5; color: #fff; padding: 15px 20px; font-weight: 600; display: flex; align-items: center; gap: 10px;">
                    <i class='bx bx-link'></i> Download from URL
                </div>
                <div class="card-content">
                    <p>Paste a direct PDF link and it will be downloaded automatically.</p>
                    <form method="post" asp-page-handler="DownloadUrl">
                        <input type="hidden" name="productId" value="@Model.Product!.Id" />
                        <div style="margin-bottom: 12px;">
                            <label style="font-size:13px; font-weight:500; color:#86868b; display:block; margin-bottom:6px;">PDF URL</label>
                            <input type="url" name="pdfUrl"
                                   placeholder="https://www.gutenberg.org/files/1342/1342-pdf.pdf"
                                   style="width:100%; border:1.5px solid #e5e5ea; border-radius:10px; padding:10px 14px; font-size:14px; outline:none; box-sizing:border-box;" />
                        </div>
                        <button type="submit" class="btn-full-primary">
                            Download &amp; Save
                        </button>
                    </form>
                </div>
            </div>

            @if (Model.Product.HasPdfAvailable)
            {
                <div class="action-card danger-border">
                    <div class="card-title-bar danger-bg">
                        <i class='bx bx-trash'></i> Remove Content
                    </div>
                    <div class="card-content">
                        <p>Permanently remove the associated PDF file from this book. This action cannot be undone.</p>
                        <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Are you sure you want to delete this PDF?');">
                            <input type="hidden" name="productId" value="@Model.Product!.Id" />
                            <button type="submit" class="btn-full-danger">
                                Delete PDF
                            </button>
                        </form>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

<script src="~/js/manage-pdf.js"></script>