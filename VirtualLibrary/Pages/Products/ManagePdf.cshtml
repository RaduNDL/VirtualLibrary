@page "{id:int}"
@model VirtualLibrary.Pages.Products.ManagePdfModel
@{
    ViewData["Title"] = "Manage PDF";
}

<div class="container py-4" style="max-width: 600px;">
    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h1 class="mb-0">📄 Manage PDF</h1>
        <a asp-page="./Details" asp-route-id="@Model.Product!.Id" class="btn btn-outline-secondary">
            Back to Book
        </a>
    </div>

    <!-- Status Message -->
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Html.Raw(Model.StatusMessage)
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Book Info Card -->
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">@Model.Product!.Title</h5>
            <p class="card-text text-muted">by @(Model.Product.Author ?? "Unknown Author")</p>

            @if (Model.Product.HasPdfAvailable)
            {
                <div class="alert alert-success mb-0">
                    <div class="d-flex align-items-center mb-2">
                        <span class="badge bg-success me-2" style="display: inline-block; width: 12px; height: 12px; border-radius: 50%;"></span>
                        <strong>PDF Available</strong>
                    </div>
                    <p class="mb-2 mt-2">Source: <span class="badge bg-info">@(Model.Product.PdfSource ?? "Unknown")</span></p>
                    <a href="~/@Model.Product.PdfFilePath" target="_blank" class="btn btn-sm btn-success">
                        <i class="bi bi-eye"></i> Preview PDF
                    </a>
                </div>
            }
            else
            {
                <div class="alert alert-warning mb-0">
                    <div class="d-flex align-items-center mb-2">
                        <span class="badge bg-danger me-2" style="display: inline-block; width: 12px; height: 12px; border-radius: 50%;"></span>
                        <strong>No PDF Available</strong>
                    </div>
                    <p class="mt-2 mb-0">Add a PDF to enable users to view the book content.</p>
                </div>
            }
        </div>
    </div>

    <!-- Search Open Library Card -->
    <div class="card mb-3 border-primary">
        <div class="card-header bg-primary text-white">
            <h6 class="mb-0">📚 Search Open Library</h6>
        </div>
        <div class="card-body">
            <p class="text-muted small mb-3">
                Automatically search and download PDF from Open Library. Works best for books in public domain.
            </p>
            <form method="post" asp-page-handler="SearchOpenLibrary">
                <input type="hidden" name="productId" value="@Model.Product!.Id" />
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> Search Open Library
                </button>
            </form>
        </div>
    </div>

    <!-- Upload PDF Card -->
    <div class="card mb-3 border-success">
        <div class="card-header bg-success text-white">
            <h6 class="mb-0">⬆️ Upload PDF</h6>
        </div>
        <div class="card-body">
            <p class="text-muted small mb-3">
                Upload a PDF file manually. Maximum file size: 100 MB.
            </p>
            <form method="post" asp-page-handler="Upload" enctype="multipart/form-data">
                <input type="hidden" name="productId" value="@Model.Product!.Id" />

                <div id="uploadArea"
                     class="border rounded p-4 mb-3 text-center"
                     style="border: 2px dashed #0d6efd; cursor: pointer; transition: background-color 0.3s;">
                    <i class="bi bi-cloud-arrow-up" style="font-size: 2em; color: #0d6efd;"></i>
                    <p class="mt-3 mb-0">
                        <strong>Drag and drop PDF here</strong><br>
                        <small class="text-muted">or click to select</small>
                    </p>
                    <input type="file"
                           name="pdfFile"
                           accept=".pdf"
                           id="fileInput"
                           style="display: none;" />
                </div>

                <button type="submit" class="btn btn-success w-100">
                    <i class="bi bi-upload"></i> Upload PDF
                </button>
            </form>
        </div>
    </div>

    <!-- Delete PDF Card -->
    @if (Model.Product.HasPdfAvailable)
    {
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h6 class="mb-0">🗑️ Delete PDF</h6>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">
                    Remove the PDF file. This action cannot be undone.
                </p>
                <form method="post" asp-page-handler="Delete"
                      onsubmit="return confirm('Are you sure you want to delete this PDF?');">
                    <input type="hidden" name="productId" value="@Model.Product!.Id" />
                    <button type="submit" class="btn btn-danger w-100">
                        <i class="bi bi-trash"></i> Delete PDF
                    </button>
                </form>
            </div>
        </div>
    }
</div>

<script src="~/js/manage-pdf.js"></script>