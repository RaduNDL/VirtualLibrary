@page "{id:int}"
@model VirtualLibrary.Pages.Products.DetailsModel
@{
    ViewData["Title"] = Model.Product.Title;
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/AdminProducts.css">

<div class="mgmt-wrapper">
    <div class="mgmt-container-wide">
        <header class="mgmt-header">
            <a href="@Model.SafeReturnUrl" class="back-link"><i class='bx bx-left-arrow-alt'></i> Back</a>
            <h2 class="mt-2">Book Details</h2>
        </header>

        <div class="details-card">
            <div class="row g-4">
                <div class="col-md-4 text-center">
                    <img src="~/@Model.Product.ImagePath" alt="@Model.Product.Title" class="details-cover" asp-append-version="true" onerror="this.src='/images/no-cover.svg';this.onerror=null;" />
                </div>
                <div class="col-md-8">
                    <div class="details-header-info">
                        <h1>@Model.Product.Title</h1>
                        @if (!string.IsNullOrWhiteSpace(Model.Product.Author))
                        {
                            <h4 class="author-name">@Model.Product.Author</h4>
                        }
                    </div>

                    <div class="details-badges">
                        @if (Model.Product.Stock > 0)
                        {
                            <span class="badge-status in-stock"><i class='bx bx-check-circle'></i> In Stock (@Model.Product.Stock)</span>
                        }
                        else
                        {
                            <span class="badge-status out-of-stock"><i class='bx bx-x-circle'></i> Out of Stock</span>
                        }
                        <span class="badge-price">@Model.Product.Price.ToString("0.00") RON</span>
                    </div>

                    <div class="details-grid mt-4">
                        <div class="detail-item">
                            <span class="label">ISBN</span>
                            <span class="value">@Model.Product.Isbn</span>
                        </div>
                        <div class="detail-item">
                            <span class="label">Category</span>
                            <span class="value">@Model.Product.Category?.Name</span>
                        </div>
                        <div class="detail-item">
                            <span class="label">Supplier</span>
                            <span class="value">@(Model.Product.Supplier?.Name ?? "—")</span>
                        </div>
                    </div>

                    <div class="details-description mt-4">
                        <h5>Description</h5>
                        <p>@Model.Product.Description</p>
                    </div>

                    <div class="details-actions mt-4">
                        @if (Model.Product.HasPdfAvailable)
                        {
                            <a asp-page="./ReadPdf" asp-route-id="@Model.Product.Id" class="btn-action-success">
                                <i class='bx bxs-file-pdf'></i> Citeste PDF
                            </a>
                        }

                        @if (User.IsInRole("Administrator"))
                        {
                            <a asp-page="./Edit" asp-route-id="@Model.Product.Id" class="btn-action-primary">
                                <i class='bx bx-edit'></i> Edit Book
                            </a>
                            <a asp-page="./ManagePdf" asp-route-id="@Model.Product.Id" class="btn-action-secondary">
                                <i class='bx bxs-file-pdf'></i> Manage PDF
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>