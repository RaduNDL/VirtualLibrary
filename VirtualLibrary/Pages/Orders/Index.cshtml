@page
@model VirtualLibrary.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "My Orders";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/UserPortal.css">

<div class="portal-wrapper">
    <div class="portal-container">
        <header class="portal-header">
            <h2><i class='bx bx-package'></i> My Orders</h2>
            <p>Track and view your purchase history.</p>
        </header>

        @if (Model.Orders == null || !Model.Orders.Any())
        {
            <div class="empty-state">
                <i class='bx bx-shopping-bag'></i>
                <h3>You have no orders yet</h3>
                <p>When you buy books, they will appear here.</p>
                <a asp-page="/Library/Index" class="btn-primary">Browse Library</a>
            </div>
        }
        else
        {
            <div class="table-card">
                <table class="portal-table">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Total</th>
                            <th class="text-right">Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.Orders)
                        {
                            <tr>
                                <td class="fw-bold text-primary">#@order.OrderId</td>
                                <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <span class="status-badge">@order.Status</span>
                                </td>
                                <td class="fw-semibold">@order.TotalAmount.ToString("0.00") RON</td>
                                <td class="text-right">
                                    <a asp-page="/Orders/OrderDetails" asp-route-id="@order.OrderId" class="btn-action-primary">
                                        <i class='bx bx-show'></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>