@page "{id:int}"
@model VirtualLibrary.Pages.Orders.OrderDetailsModel
@{
    ViewData["Title"] = "Order Details";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/UserPortal.css">

<div class="portal-wrapper">
    <div class="portal-container">
        <header class="portal-header flex-between">
            <div>
                <a asp-page="Index" class="back-link"><i class='bx bx-left-arrow-alt'></i> Back to Orders</a>
                <h2 class="mt-2">Order #@Model.Order.OrderId</h2>
            </div>
            <div class="order-total-highlight">
                <span>Total Amount</span>
                <h3>@Model.Order.TotalAmount.ToString("0.00") RON</h3>
            </div>
        </header>

        <div class="summary-cards-grid">
            <div class="info-card">
                <i class='bx bx-calendar'></i>
                <div>
                    <span>Order Date</span>
                    <strong>@Model.Order.OrderDate.ToString("f")</strong>
                </div>
            </div>
            <div class="info-card">
                <i class='bx bx-loader-circle'></i>
                <div>
                    <span>Status</span>
                    <strong class="text-accent">@Model.Order.Status</strong>
                </div>
            </div>
        </div>

        <h3 class="section-subtitle">Items in this order</h3>

        <div class="table-card mt-3">
            <table class="portal-table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th class="text-center">Quantity</th>
                        <th class="text-right">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Order.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Product.Title</td>
                            <td>@item.Price.ToString("0.00") RON</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-right fw-bold">@((item.Price * item.Quantity).ToString("0.00")) RON</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>