@page
@model VirtualLibrary.Pages.Billing.IndexModel
@{
    ViewData["Title"] = "Secure Checkout";
   
}

<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/Billing.css">

<div class="checkout-wrapper">
    <div class="checkout-container">
        <header class="checkout-header">
            <a asp-page="/Index" class="back-btn"><i class='bx bx-left-arrow-alt'></i> Back to Library</a>
            <h2>Secure Checkout</h2>
            <p>Complete your purchase by providing your payment details.</p>
        </header>

        @if (Model.CartItems == null || !Model.CartItems.Any())
        {
            <div class="empty-cart-state">
                <i class='bx bx-cart-add'></i>
                <h3>Your cart is empty</h3>
                <p>Add some books to your library to proceed.</p>
                <a asp-page="/Index" class="btn-primary">Browse Books</a>
            </div>
        }
        else
        {
            <div class="checkout-grid">
                <div class="form-section">
                    <form method="post" id="payment-form">
                        <div class="card-glass">
                            <h5 class="section-title"><i class='bx bx-map-pin'></i> Shipping Information</h5>
                            <div class="input-group-modern">
                                <label asp-for="Checkout.FullName"></label>
                                <input asp-for="Checkout.FullName" placeholder="John Doe" />
                                <span asp-validation-for="Checkout.FullName" class="text-error"></span>
                            </div>

                            <div class="input-group-modern">
                                <label asp-for="Checkout.Address"></label>
                                <input asp-for="Checkout.Address" placeholder="Street Name, No. 5" />
                                <span asp-validation-for="Checkout.Address" class="text-error"></span>
                            </div>

                            <div class="row-flex">
                                <div class="input-group-modern">
                                    <label asp-for="Checkout.City"></label>
                                    <input asp-for="Checkout.City" placeholder="Bucharest" />
                                    <span asp-validation-for="Checkout.City" class="text-error"></span>
                                </div>
                                <div class="input-group-modern">
                                    <label asp-for="Checkout.PostalCode"></label>
                                    <input asp-for="Checkout.PostalCode" placeholder="123456" />
                                    <span asp-validation-for="Checkout.PostalCode" class="text-error"></span>
                                </div>
                            </div>

                            <div class="input-group-modern">
                                <label asp-for="Checkout.PhoneNumber"></label>
                                <input asp-for="Checkout.PhoneNumber" placeholder="07xx xxx xxx" />
                                <span asp-validation-for="Checkout.PhoneNumber" class="text-error"></span>
                            </div>
                        </div>

                        <div class="card-glass mt-4">
                            <h5 class="section-title"><i class='bx bx-credit-card'></i> Payment Details</h5>
                            <div class="input-group-modern">
                                <label asp-for="Checkout.CardNumber"></label>
                                <div class="card-input-wrapper">
                                    <input asp-for="Checkout.CardNumber" inputmode="numeric" maxlength="16" placeholder="0000 0000 0000 0000" />
                                    <i class='bx bxl-visa'></i>
                                </div>
                                <span asp-validation-for="Checkout.CardNumber" class="text-error"></span>
                            </div>

                            <div class="row-flex">
                                <div class="input-group-modern">
                                    <label>Expiry Month</label>
                                    <input asp-for="Checkout.ExpiryMonth" placeholder="MM" />
                                    <span asp-validation-for="Checkout.ExpiryMonth" class="text-error"></span>
                                </div>
                                <div class="input-group-modern">
                                    <label>Expiry Year</label>
                                    <input asp-for="Checkout.ExpiryYear" placeholder="YYYY" />
                                    <span asp-validation-for="Checkout.ExpiryYear" class="text-error"></span>
                                </div>
                                <div class="input-group-modern">
                                    <label asp-for="Checkout.Cvv"></label>
                                    <input asp-for="Checkout.Cvv" maxlength="3" placeholder="123" />
                                    <span asp-validation-for="Checkout.Cvv" class="text-error"></span>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="pay-button">
                            <span>Confirm Order &middot; @Model.Total.ToString("0.00") RON</span>
                            <i class='bx bx-lock-alt'></i>
                        </button>
                    </form>
                </div>

                <div class="summary-section">
                    <div class="card-summary">
                        <h3>Order Summary</h3>
                        <div class="order-items">
                            @foreach (var item in Model.CartItems)
                            {
                                <div class="item">
                                    <div class="item-info">
                                        <span class="item-name">@item.Product.Title</span>
                                        <span class="item-qty">Qty: @item.Quantity</span>
                                    </div>
                                    <span class="item-price">@((item.Product.Price * item.Quantity).ToString("0.00")) RON</span>
                                </div>
                            }
                        </div>
                        <div class="total-divider"></div>
                        <div class="summary-row">
                            <span>Subtotal</span>
                            <span>@Model.Total.ToString("0.00") RON</span>
                        </div>
                        <div class="summary-row">
                            <span>Shipping</span>
                            <span class="free">FREE</span>
                        </div>
                        <div class="summary-row total">
                            <span>Total</span>
                            <span>@Model.Total.ToString("0.00") RON</span>
                        </div>
                    </div>

                    <div class="trust-badges">
                        <p><i class='bx bxs-shield-checked'></i> Secure 256-bit SSL encryption</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}