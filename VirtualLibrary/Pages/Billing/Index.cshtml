@page
@model VirtualLibrary.Pages.Billing.IndexModel
@{
    ViewData["Title"] = "Billing & Checkout";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2 class="text-primary mb-3">Billing & Checkout</h2>

    @if (Model.CartItems == null || !Model.CartItems.Any())
    {
        <div class="alert alert-info">Your cart is empty.</div>
    }
    else
    {
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Order Summary</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th class="text-end">Price</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.CartItems)
                                {
                                    <tr>
                                        <td>@item.Product.Title</td>
                                        <td class="text-end">@item.Product.Price.ToString("0.00")</td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td class="text-end">
                                            @(item.Product.Price* item.Quantity).ToString("0.00")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <span class="fw-semibold">Total:</span>
                            <span class="fw-bold text-success">
                                @Model.Total.ToString("0.00") RON
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Billing Details</h5>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <div class="mb-3">
                                <label asp-for="Checkout.FullName" class="form-label"></label>
                                <input asp-for="Checkout.FullName" class="form-control" />
                                <span asp-validation-for="Checkout.FullName" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Checkout.Address" class="form-label"></label>
                                <input asp-for="Checkout.Address" class="form-control" />
                                <span asp-validation-for="Checkout.Address" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Checkout.City" class="form-label"></label>
                                <input asp-for="Checkout.City" class="form-control" />
                                <span asp-validation-for="Checkout.City" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Checkout.PostalCode" class="form-label"></label>
                                <input asp-for="Checkout.PostalCode" class="form-control" />
                                <span asp-validation-for="Checkout.PostalCode" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Checkout.PhoneNumber" class="form-label"></label>
                                <input asp-for="Checkout.PhoneNumber" class="form-control" />
                                <span asp-validation-for="Checkout.PhoneNumber" class="text-danger"></span>
                            </div>

                            <hr />

                            <h6 class="mb-3">Payment details</h6>

                            <div class="mb-3">
                                <label asp-for="Checkout.CardNumber" class="form-label"></label>
                                <input asp-for="Checkout.CardNumber"
                                       class="form-control"
                                       inputmode="numeric"
                                       maxlength="19" />
                                <span asp-validation-for="Checkout.CardNumber" class="text-danger"></span>
                            </div>

                            <div class="row">
                                <div class="col-6 mb-3">
                                    <label asp-for="Checkout.ExpiryMonth" class="form-label"></label>
                                    <input asp-for="Checkout.ExpiryMonth"
                                           class="form-control"
                                           min="1"
                                           max="12" />
                                    <span asp-validation-for="Checkout.ExpiryMonth" class="text-danger"></span>
                                </div>
                                <div class="col-6 mb-3">
                                    <label asp-for="Checkout.ExpiryYear" class="form-label"></label>
                                    <input asp-for="Checkout.ExpiryYear"
                                           class="form-control"
                                           min="2024"
                                           max="2100" />
                                    <span asp-validation-for="Checkout.ExpiryYear" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Checkout.Cvv" class="form-label"></label>
                                <input asp-for="Checkout.Cvv"
                                       class="form-control"
                                       inputmode="numeric"
                                       maxlength="4" />
                                <span asp-validation-for="Checkout.Cvv" class="text-danger"></span>
                            </div>

                            <button type="submit" class="btn btn-success w-100">
                                <i class="bi bi-check2-circle"></i> Confirm &amp; Pay
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
