@page
@using VirtualLibrary.Models
@model VirtualLibrary.Pages.Audiobooks.IndexModel
@{
    ViewData["Title"] = "My Audiobooks";
}

<div class="container mt-4">
    <div class="p-5 mb-4 rounded-3 bg-primary text-white">
        <h1 class="display-5 fw-bold mb-3">🎧 My Audiobooks</h1>
        <p class="lead mb-4">Generate and manage your personal audiobook library</p>

        <div class="row text-center">
            <div class="col-md-6 mb-3 mb-md-0">
                <div class="p-3" style="background: rgba(255,255,255,0.1); border-radius: 8px;">
                    <div class="fs-3 fw-bold">@Model.Products.Count</div>
                    <small>Books Available</small>
                </div>
            </div>

            <div class="col-md-6">
                <div class="p-3" style="background: rgba(255,255,255,0.1); border-radius: 8px;">
                    <div class="fs-3 fw-bold">@Model.TotalAudiobooksGenerated</div>
                    <small>Audiobooks Generated</small>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show">
            @Html.Raw(Model.StatusMessage)
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Products.Any())
    {
        <div class="text-center py-5">
            <div class="display-1 text-muted mb-3">📚</div>
            <h3 class="text-muted">No Books Available</h3>
            <p class="text-muted mb-4">Browse our library to find books to convert to audiobooks</p>

            <a href="@Url.Page("/Library/Index")" class="btn btn-primary btn-lg">
                Browse Library
            </a>
        </div>
    }
    else
    {
        <div class="mb-3">
            <small class="text-muted">Showing all @Model.Products.Count available books</small>
        </div>

        @foreach (var product in Model.Products)
        {
            var audiobook = Model.AudiobookStatus[product.Id];
            var isProcessing = audiobook?.Status == AudiobookStatus.Processing;
            var isCompleted = audiobook?.Status == AudiobookStatus.Completed;

            <div class="card mb-3 shadow-sm">
                <div class="card-body">
                    <div class="row g-3">

                        <div class="col-md-2 text-center">
                            <img src="~/@product.ImagePath"
                                 alt="@product.Title"
                                 class="img-thumbnail"
                                 style="width:100px;height:150px;object-fit:cover"
                                 onerror="this.src='/images/no-cover.svg'" />
                        </div>

                        <div class="col-md-10">

                            <h5 class="card-title mb-1">@product.Title</h5>

                            <p class="card-text text-muted mb-2">
                                <strong>by @(product.Author ?? "Unknown Author")</strong>
                            </p>

                            @if (!string.IsNullOrWhiteSpace(product.Category?.Name))
                            {
                                <span class="badge bg-light text-dark mb-3">@product.Category.Name</span>
                            }

                            <div class="mt-3 pt-3 border-top">

                                @if (audiobook == null)
                                {
                                    <span class="badge bg-warning text-dark">
                                        Not Generated
                                    </span>
                                }
                                else
                                {
                                    @if (audiobook.Status == AudiobookStatus.Completed)
                                    {
                                        <span class="badge bg-success">
                                            Completed
                                        </span>
                                    }
                                    else if (audiobook.Status == AudiobookStatus.Processing)
                                    {
                                        <span class="badge bg-info">
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                            Processing
                                        </span>
                                    }
                                    else if (audiobook.Status == AudiobookStatus.Failed)
                                    {
                                        <span class="badge bg-danger">
                                            Failed
                                        </span>
                                    }
                                    else if (audiobook.Status == AudiobookStatus.Pending)
                                    {
                                        <span class="badge bg-secondary">
                                            Pending
                                        </span>
                                    }

                                    @if (isCompleted && audiobook.Duration.HasValue)
                                    {
                                        <small class="d-block text-muted mt-2">
                                            Duration: @audiobook.Duration?.ToString(@"hh\:mm\:ss")
                                        </small>
                                    }

                                    @if (!string.IsNullOrEmpty(audiobook.ErrorMessage) && audiobook.Status == AudiobookStatus.Failed)
                                    {
                                        <div class="alert alert-danger mt-2 mb-0 py-2">
                                            <small>@audiobook.ErrorMessage</small>
                                        </div>
                                    }
                                }

                            </div>

                            <div class="mt-3 pt-3 border-top">

                                @if (audiobook == null || audiobook.CanRetry)
                                {
                                    <form method="post" asp-page-handler="Generate" class="d-inline">
                                        <input type="hidden" name="productId" value="@product.Id" />

                                        <button type="submit" class="btn btn-sm btn-primary">
                                            Generate Audiobook
                                        </button>
                                    </form>
                                }
                                else if (isProcessing)
                                {
                                    <button class="btn btn-sm btn-secondary" disabled>
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                        Generating...
                                    </button>
                                }
                                else if (isCompleted)
                                {
                                    <a href="/Audiobooks/Index?handler=Download&audiobookId=@audiobook.AudiobookId"
                                       class="btn btn-sm btn-success" download>
                                        Download MP3
                                    </a>

                                    @if (product.HasPdfAvailable)
                                    {
                                        <a href="/Audiobooks/PdfViewer?productId=@product.Id"
                                           class="btn btn-sm btn-info">
                                            Read & Listen
                                        </a>
                                    }

                                    <form method="post"
                                          asp-page-handler="Delete"
                                          class="d-inline"
                                          onsubmit="return confirm('Delete this audiobook?');">

                                        <input type="hidden"
                                               name="audiobookId"
                                               value="@audiobook.AudiobookId" />

                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger">
                                            Delete
                                        </button>
                                    </form>
                                }

                            </div>

                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

<script src="~/js/audiobooks.js"></script>