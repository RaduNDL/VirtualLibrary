@page "{productId:int}"
@model VirtualLibrary.Pages.Audiobooks.PdfViewerModel
@{
    ViewData["Title"] = "PDF Viewer - " + Model.Product?.Title;
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/audiobook-player.css" asp-append-version="true" />

<div class="d-flex vh-100 pdf-layout">

    <div class="flex-grow-1 bg-light p-3 overflow-auto" id="pdfContainer">
        @if (Model.Product?.HasPdfAvailable == true)
        {
            <iframe src="~/@Model.Product.PdfFilePath"
                    class="w-100 h-100 border rounded pdf-iframe"></iframe>
        }
        else
        {
            <div class="d-flex align-items-center justify-content-center h-100">
                <div class="text-center">
                    <div class="display-1 text-muted mb-3">📄</div>
                    <h3 class="text-muted">PDF Not Available</h3>
                    <p class="text-muted">This book doesn't have a PDF available yet.</p>
                    <a href="@Url.Page("/Audiobooks/Index")" class="btn btn-primary mt-3">
                        <i class="bi bi-arrow-left"></i> Back to My Audiobooks
                    </a>
                </div>
            </div>
        }
    </div>

    <div class="ab-panel bg-white border-start overflow-auto pdf-side-panel">
        <div class="p-3">
            <a href="@Url.Page("/Audiobooks/Index")" class="btn btn-outline-secondary w-100 btn-sm mb-3">
                <i class="bi bi-arrow-left"></i> Back
            </a>

            <div class="text-center mb-3 p-3 bg-light rounded">
                <img src="~/@Model.Product?.ImagePath"
                     alt="@Model.Product?.Title"
                     class="img-thumbnail mb-2 pdf-cover-img"
                     onerror="this.src='/images/no-cover.svg'" />
                <div class="fw-bold small">@Model.Product?.Title</div>
                <small class="text-muted">@(Model.Product?.Author ?? "Unknown")</small>
            </div>

            @if (Model.Audiobook?.Status == "Completed")
            {
                <div class="ab-section mb-3">
                    <h6 class="fw-bold mb-2 pb-1 border-bottom">🎧 MP3 Audio</h6>
                    <audio id="audioPlayer" class="w-100 mb-2" controls>
                        <source src="~/@Model.Audiobook.AudioFilePath" type="audio/mpeg" />
                    </audio>
                    <div class="d-flex justify-content-between small text-muted mb-1">
                        <span id="currentTime">0:00</span>
                        <span id="duration">0:00</span>
                    </div>
                    <div id="progressBar" class="mb-2 bg-light rounded progress-bar-track">
                        <div id="progressFill" class="bg-primary h-100 rounded progress-bar-fill"></div>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-primary flex-grow-1" id="playPauseBtn">
                            <i class="bi bi-play-fill"></i> Play
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" id="muteBtn">
                            <i class="bi bi-volume-up"></i>
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<script src="~/js/pdf-viewer.js"></script>
<script src="~/js/manage-pdf.js"></script>