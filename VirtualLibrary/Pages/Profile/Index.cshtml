@page
@model VirtualLibrary.Pages.Profile.IndexModel
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h3 class="mb-0">
                        <i class="bi bi-person-circle me-2"></i> My Profile
                    </h3>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4 text-center">
                        <i class="bi bi-person-circle text-primary" style="font-size: 5rem;"></i>
                        <h4 class="mt-3 text-secondary">@Model.Username</h4>
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4 fw-semibold">
                            <i class="bi bi-envelope-fill me-1 text-primary"></i> Email
                        </dt>
                        <dd class="col-sm-8">@Model.Email</dd>

                        <dt class="col-sm-4 fw-semibold">
                            <i class="bi bi-person-badge-fill me-1 text-primary"></i> Role
                        </dt>
                        <dd class="col-sm-8">
                            @if (User.IsInRole("Administrator"))
                            {
                                <span class="badge bg-danger">Administrator</span>
                            }
                            else
                            {
                                <span class="badge bg-success">User</span>
                            }
                        </dd>
                    </dl>
                </div>
                <div class="card-footer text-center">
                    <a asp-page="/Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left-circle"></i> Back to Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
