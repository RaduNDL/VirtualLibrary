@page
@model VirtualLibrary.Pages.Profile.IndexModel
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/Profile.css">

<div class="profile-wrapper">
    <div class="profile-container">
        <div class="profile-card">
            <div class="profile-cover"></div>

            <div class="profile-avatar-section">
                <div class="profile-avatar">
                    <i class='bx bx-user'></i>
                </div>
                <h3 class="profile-username">@Model.Username</h3>

                @if (User.IsInRole("Administrator"))
                {
                    <span class="role-badge badge-admin">
                        <i class='bx bx-shield-quarter'></i> Administrator
                    </span>
                }
                else
                {
                    <span class="role-badge badge-user">
                        <i class='bx bx-user-circle'></i> User
                    </span>
                }
            </div>

            <div class="profile-details">
                <div class="detail-group">
                    <div class="detail-icon">
                        <i class='bx bx-envelope'></i>
                    </div>
                    <div class="detail-text">
                        <span class="detail-label">Email Address</span>
                        <span class="detail-value">@Model.Email</span>
                    </div>
                </div>
            </div>

            <div class="profile-actions">
                <a asp-page="/Index" class="btn-back">
                    <i class='bx bx-left-arrow-alt'></i> Back to Home
                </a>
            </div>
        </div>
    </div>
</div>