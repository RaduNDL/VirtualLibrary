@page
@model VirtualLibrary.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Log in";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/Auth.css">

<div class="auth-wrapper">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header text-primary">
                <i class='bx bx-user-circle'></i>
                <h2>Welcome Back</h2>
                <p>Login to your Virtual Library account</p>
            </div>

            <form method="post" class="auth-form" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-error-summary mb-3"></div>

                <div class="input-group-modern">
                    <label asp-for="Input.Email">Email Address</label>
                    <div class="input-with-icon">
                        <i class='bx bx-envelope'></i>
                        <input asp-for="Input.Email" autocomplete="username" placeholder="name@example.com" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-error"></span>
                </div>

                <div class="input-group-modern">
                    <label asp-for="Input.Password">Password</label>
                    <div class="input-with-icon">
                        <i class='bx bx-lock-alt'></i>
                        <input asp-for="Input.Password" type="password" autocomplete="current-password" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-error"></span>
                </div>

                <div class="form-actions mt-4">
                    <button type="submit" class="btn-auth-primary w-100">
                        Log In <i class='bx bx-right-arrow-alt'></i>
                    </button>
                </div>
            </form>

            <div class="auth-footer">
                <p>Don’t have an account?</p>
                <a asp-area="Identity" asp-page="/Account/Register" class="btn-auth-outline w-100">
                    <i class='bx bx-user-plus'></i> Create an Account
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}