@page
@model VirtualLibrary.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/Auth.css">

<div class="auth-wrapper">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header text-success">
                <i class='bx bx-user-plus'></i>
                <h2>Create Account</h2>
                <p>Join Virtual Library and explore our world of books</p>
            </div>

            <form method="post" class="auth-form" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-error-summary mb-3"></div>

                <div class="input-group-modern">
                    <label asp-for="Input.Email">Email Address</label>
                    <div class="input-with-icon">
                        <i class='bx bx-envelope'></i>
                        <input asp-for="Input.Email" autocomplete="username" placeholder="name@example.com" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-error"></span>
                </div>

                <div class="input-group-modern">
                    <label asp-for="Input.Password">Password</label>
                    <div class="input-with-icon">
                        <i class='bx bx-lock-alt'></i>
                        <input asp-for="Input.Password" type="password" autocomplete="new-password" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-error"></span>
                </div>

                <div class="input-group-modern">
                    <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                    <div class="input-with-icon">
                        <i class='bx bx-check-shield'></i>
                        <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-error"></span>
                </div>

                <div class="form-actions mt-4">
                    <button type="submit" class="btn-auth-success w-100">
                        <i class='bx bx-check-circle'></i> Register Now
                    </button>
                </div>
            </form>

            <div class="auth-footer">
                <p>Already have an account?</p>
                <a asp-area="Identity" asp-page="/Account/Login" class="btn-auth-outline-success w-100">
                    <i class='bx bx-log-in'></i> Log In
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}